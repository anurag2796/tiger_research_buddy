# ──────────────────────────────────────────────────────────────────────────────
# Python (github.com/github/gitignore/blob/main/Python.gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django / Flask / Scrapy
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache
.scrapy

# Sphinx documentation
docs/_build/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# Environments
.env
.envrc
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
__pypackages__/

# Spyder / Rope
.spyderproject
.spyproject
.ropeproject

# Mypy / Pyre / Pytype
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/

# Ruff / other linters
.ruff_cache/
.pypirc

# Streamlit secrets (keep .streamlit/ config but not secrets)
.streamlit/secrets.toml

# macOS
.DS_Store
**/.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# ──────────────────────────────────────────────────────────────────────────────
# TigerResearchBuddy — Project-specific
# ──────────────────────────────────────────────────────────────────────────────

# Secrets — keep example for onboarding
.env
!.env.example

# --- Downloaded & Generated Data (large, machine-generated) ------------------
data/pdfs/
data/papers/
data/publications/
data/research_cards/
data/faculty_profiles/
data/research_areas/
data/viz/
data/debug_failures/
data/debug_*/

# Restricted-mode equivalents
data/restricted/pdfs/
data/restricted/papers/
data/restricted/publications/
data/restricted/research_cards/

# Crawler output JSON
data/rit_data.json
data/rit_data_v2.json
data/rit_data_test.json
data/extended_data.json
data/comprehensive_data.json
data/entity_mappings.json
data/target_urls.json
data/restricted/rit_data_restricted.json

# Crawl checkpoints
data/crawler_checkpoint_*.json
data/restricted/crawler_checkpoint_*.json

# Knowledge graph exports (can be 5–20 MB each)
data/site_graph.gml
data/tiger_brain.gml
data/tiger_brain.json
data/tiger_brain_refined.gml
data/tiger_brain_viz.html
data/knowledge_graph.pkl
data/restricted/site_graph.gml
data/restricted/tiger_brain.gml

# --- Databases ---------------------------------------------------------------
data/tiger_research.db
data/chroma/
data/chroma_test/
data/lancedb/
data/kuzu_db*
data/kuzu_db/
data/restricted/chroma/
data/restricted/lancedb/

# --- Caches ------------------------------------------------------------------
data/cache/
.cache/

# --- Runtime artifacts -------------------------------------------------------
# Dagster temp dirs
.tmp_dagster_home_*/

# Data backups
data_backup_*/

# Logs
logs/
data/*.log
data/full_pipeline.log

# --- Keep empty directory structure for fresh clones -------------------------
!data/.gitkeep
!data/restricted/.gitkeep
!data/taxonomies/

tests/output/

