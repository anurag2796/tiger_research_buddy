# TigerResearchBuddy Environment Variables
# Copy this file to .env and fill in your values

# ── Google Gemini API ──────────────────────────────────────────────────────
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Hardware Tuning ────────────────────────────────────────────────────────
# These are AUTO-DETECTED if not set (macOS defaults shown / Orin values in comments).
# Override here to lock in values regardless of platform detection.

# Max concurrent Ollama async LLM calls.
# macOS M4 Max: 2  |  Jetson Orin: 1  (prevents VRAM OOM panic)
OLLAMA_CHAT_CONCURRENCY=2

# Max concurrent PDF distillation tasks.
# macOS M4 Max: 3  |  Jetson Orin: 1  (prevents CPU/RAM thrashing)
DISTILLER_CONCURRENCY=3

# Ollama context window (num_ctx tokens passed to the model).
# macOS M4 Max: 16384  |  Jetson Orin: 8192
LLM_CONTEXT_WINDOW=16384

# SentenceTransformers device for the nomic-embed-text embedding model.
# auto-detected: cpu (macOS — MPS has meta-tensor bug), cuda (Jetson Orin w/ CUDA)
# Uncomment to override:
# EMBEDDING_DEVICE=cpu

# PDF extraction engine.
# macOS: apple_fast  |  Linux/Orin: pymupdf  (marker requires PyTorch inference)
# Uncomment to override:
# PDF_ENGINE=pymupdf

# ── Conversational Memory ──────────────────────────────────────────────────
# Sliding window size (number of individual messages kept in-process per session).
# macOS M4 Max: 20 (10 turns)  |  Jetson Orin: 6 (3 turns)
MEMORY_WINDOW=20

# Enable LanceDB long-term semantic memory (embeds and persists every turn).
# Recommended: true on M4 Max, false on Jetson Orin (RAM-constrained).
ENABLE_LONG_TERM_MEMORY=false

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Defaults to wildcard (*) if this var is unset — NOT recommended for production.
ALLOWED_ORIGINS=http://localhost:3000
