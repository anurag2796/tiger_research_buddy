# ═══════════════════════════════════════════════════════════════════════════════
# TigerResearchBuddy — Jetson Orin Optimized Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env on the Jetson:  cp .env.jetson .env
#
# These values are tuned for Jetson AGX Orin (32GB unified memory).
# Adjust OLLAMA_CHAT_CONCURRENCY and LLM_CONTEXT_WINDOW DOWN if using
# Orin NX (16GB) or Orin Nano (8GB).

# ── Google Gemini API (optional — Ollama is primary on Jetson) ────────────────
GEMINI_API_KEY=AIzaSyB911HGKjYjYYDnNXlA2MJpKSJm3fe57AI
GEMINI_MODEL=gemini-2.0-flash

# ── Hardware Tuning for Jetson Orin ───────────────────────────────────────────
OLLAMA_CHAT_CONCURRENCY=1
DISTILLER_CONCURRENCY=1
LLM_CONTEXT_WINDOW=8192
EMBEDDING_DEVICE=cuda
PDF_ENGINE=pymupdf

# ── Conversational Memory ─────────────────────────────────────────────────────
MEMORY_WINDOW=10
ENABLE_LONG_TERM_MEMORY=false

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── SerpAPI (for Google Scholar) ──────────────────────────────────────────────
SERPAPI_KEY=bdbef6cf5fbd3f1d7fff7658b187252aef0a4bc862fadd592a7aaa9f3be8806d
